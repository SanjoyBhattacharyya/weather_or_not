<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="horizontal"
    android:padding="12dp">

    <!-- Left Section: Weather Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.1"
        android:orientation="vertical"
        android:gravity="center_vertical">
        
        <TextView
            android:id="@+id/widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Weather or Not"
            android:textColor="#94A3B8"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_temp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/widget_location"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="New York"
            android:textColor="#E2E8F0"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginTop="2dp"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_condition"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Loading..."
            android:textColor="#38BDF8"
            android:textSize="11sp"
            android:layout_marginTop="2dp"
            android:singleLine="true"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- Vertical Divider -->
    <FrameLayout
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="#334155"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp" />

    <!-- Right Section: Days plans -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.4"
        android:orientation="vertical"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📅 TODAY'S PLANS"
            android:textColor="#94A3B8"
            android:textSize="10sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <!-- Static Placeholder when no plans -->
        <TextView
            android:id="@+id/widget_no_plans"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No plans today!\nWear sunglasses &amp; sunscreen! 🕶️"
            android:textColor="#38BDF8"
            android:textSize="11sp"
            android:visibility="gone" />

        <!-- Plans container -->
        <LinearLayout
            android:id="@+id/widget_plans_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Plan Item 1 -->
            <LinearLayout
                android:id="@+id/widget_plan_item1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="3dp"
                android:gravity="center_vertical"
                android:visibility="visible">
                <TextView
                    android:id="@+id/widget_plan_time1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10:00"
                    android:textColor="#38BDF8"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="6dp" />
                <TextView
                    android:id="@+id/widget_plan_title1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Morning Run"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:singleLine="true"
                    android:ellipsize="end" />
            </LinearLayout>

            <!-- Plan Item 2 -->
            <LinearLayout
                android:id="@+id/widget_plan_item2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="3dp"
                android:gravity="center_vertical"
                android:visibility="visible">
                <TextView
                    android:id="@+id/widget_plan_time2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="14:30"
                    android:textColor="#38BDF8"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="6dp" />
                <TextView
                    android:id="@+id/widget_plan_title2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Client meeting"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:singleLine="true"
                    android:ellipsize="end" />
            </LinearLayout>

            <!-- Plan Item 3 -->
            <LinearLayout
                android:id="@+id/widget_plan_item3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="visible">
                <TextView
                    android:id="@+id/widget_plan_time3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="19:00"
                    android:textColor="#38BDF8"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="6dp" />
                <TextView
                    android:id="@+id/widget_plan_title3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Dinner with Sarah"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:singleLine="true"
                    android:ellipsize="end" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
